#!/bin/sh
# Pre-push hook: run backend tests, lint, and frontend tests before push.
# Skips if the push only contains documentation changes.

echo "=== Running pre-push checks ==="

# Run ruff linting
echo "--- ruff check ---"
python -m ruff check .
if [ $? -ne 0 ]; then
    echo "✖ ruff check failed. Fix issues before pushing."
    exit 1
fi
echo "✓ ruff check passed"

# Run backend tests
echo "--- pytest ---"
python -m pytest --tb=short -q
if [ $? -ne 0 ]; then
    echo "✖ Tests failed. Fix before pushing."
    exit 1
fi
echo "✓ Backend tests passed"

# Run frontend tests (if they exist)
if [ -f "package.json" ]; then
    echo "--- vitest ---"
    npm test -- --run 2>/dev/null
    if [ $? -ne 0 ]; then
        echo "⚠ Frontend tests failed (non-blocking for now)"
    else
        echo "✓ Frontend tests passed"
    fi
fi

echo "=== All pre-push checks passed ==="
exit 0
